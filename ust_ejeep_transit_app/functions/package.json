{
  "name": "ust-ejeep-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for UST E-Jeep Transit App",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "serve": "npm run build && firebase emulators:start --only functions"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "firebase-functions": "^4.5.0",
    "firebase-admin": "^11.11.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "fast-check": "^3.14.0",
    "@firebase/rules-unit-testing": "^3.0.1",
    "@types/jest": "^29.5.11"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ]
  }
}
